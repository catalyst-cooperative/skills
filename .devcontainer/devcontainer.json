{
  "name": "Agent Skills Sandbox",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
  "containerEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "GEMINI_API_KEY": "${localEnv:GEMINI_API_KEY}",
    "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}",
    "GOOGLE_API_KEY": "${localEnv:GOOGLE_API_KEY}",
    "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}",
    "OPENROUTER_API_KEY": "${localEnv:OPENROUTER_API_KEY}"
  },
  "mounts": [
    "source=agent-skills-pixi,target=/workspace/.pixi,type=volume"
  ],
  "postCreateCommand": "pixi run devcontainer-install",
  "remoteUser": "ubuntu",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "charliermarsh.ruff",
        "ms-toolsai.jupyter",
        "tamasfe.even-better-toml",
        "DavidAnson.vscode-markdownlint",
        "renan-r-santos.pixi-code"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspace/.pixi/envs/default/bin/python",
        "python.terminal.activateEnvironment": false,
        "python.createEnvironment.trigger": "off",
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true
        },
        "[json]": {
          "editor.tabSize": 2
        },
        "[jsonc]": {
          "editor.tabSize": 2
        }
      }
    }
  }
}
